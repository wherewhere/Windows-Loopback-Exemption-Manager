<Page
    x:Class="LoopBack.Pages.ManagePage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:animatedvisuals="using:Microsoft.UI.Xaml.Controls.AnimatedVisuals"
    xmlns:contract8Present="http://schemas.microsoft.com/winfx/2006/xaml/presentation?IsApiContractPresent(Windows.Foundation.UniversalApiContract, 8)"
    xmlns:converters="using:CommunityToolkit.WinUI.Converters"
    xmlns:cwuc="using:CommunityToolkit.WinUI.Controls"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="using:LoopBack.Pages"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:metadata="using:LoopBack.Metadata"
    xmlns:muxc="using:Microsoft.UI.Xaml.Controls"
    xmlns:ui="using:CommunityToolkit.WinUI"
    xmlns:viewmodels="using:LoopBack.ViewModels"
    d:DataContext="{d:DesignInstance Type=viewmodels:ManageViewModel}"
    DataContext="{x:Bind Provider}"
    mc:Ignorable="d">
    <Page.Resources>
        <converters:StringVisibilityConverter x:Key="StringVisibilityConverter" />
    </Page.Resources>
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="40" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>
        <Grid.ChildrenTransitions>
            <TransitionCollection>
                <ReorderThemeTransition />
            </TransitionCollection>
        </Grid.ChildrenTransitions>
        <ScrollViewer
            HorizontalAlignment="Center"
            HorizontalScrollBarVisibility="Hidden"
            HorizontalScrollMode="Auto"
            VerticalScrollBarVisibility="Disabled"
            VerticalScrollMode="Disabled">
            <StackPanel
                Margin="16,0"
                HorizontalAlignment="Center"
                Orientation="Horizontal"
                Spacing="16">
                <StackPanel.ChildrenTransitions>
                    <TransitionCollection>
                        <ReorderThemeTransition />
                    </TransitionCollection>
                </StackPanel.ChildrenTransitions>
                <TextBlock x:Uid="/ManagePage/SearchTitle" VerticalAlignment="Center" />
                <AutoSuggestBox
                    x:Uid="/ManagePage/SearchBox"
                    Grid.Row="0"
                    Width="250"
                    HorizontalAlignment="Left"
                    VerticalAlignment="Center"
                    QuerySubmitted="AutoSuggestBox_QuerySubmitted"
                    TextChanged="AutoSuggestBox_TextChanged">
                    <AutoSuggestBox.QueryIcon>
                        <muxc:AnimatedIcon>
                            <muxc:AnimatedIcon.Source>
                                <animatedvisuals:AnimatedFindVisualSource />
                            </muxc:AnimatedIcon.Source>
                            <muxc:AnimatedIcon.FallbackIconSource>
                                <muxc:FontIconSource
                                    FontFamily="{StaticResource SymbolThemeFontFamily}"
                                    FontSize="12"
                                    Glyph="&#xE721;" />
                            </muxc:AnimatedIcon.FallbackIconSource>
                        </muxc:AnimatedIcon>
                    </AutoSuggestBox.QueryIcon>
                </AutoSuggestBox>
                <CheckBox
                    x:Uid="/ManagePage/ExemptButton"
                    MinWidth="0"
                    VerticalAlignment="Center"
                    Click="CheckBox_Click">
                    <CheckBox.KeyboardAccelerators>
                        <KeyboardAccelerator Key="A" Modifiers="Control" />
                    </CheckBox.KeyboardAccelerators>
                </CheckBox>
                <Button
                    x:Name="SaveButton"
                    x:Uid="/ManagePage/SaveButton"
                    Width="100"
                    VerticalAlignment="Center"
                    IsEnabled="{x:Bind Provider.IsDirty, Mode=OneWay}"
                    Style="{StaticResource AccentButtonStyle}">
                    <Button.KeyboardAccelerators>
                        <KeyboardAccelerator Key="S" Modifiers="Control" />
                    </Button.KeyboardAccelerators>
                    <Button.Flyout>
                        <Flyout contract8Present:ShouldConstrainToRootBounds="False">
                            <StackPanel Spacing="12">
                                <TextBlock x:Uid="/ManagePage/SaveFlyoutTitle" Style="{ThemeResource BaseTextBlockStyle}" />
                                <Button
                                    Width="100"
                                    HorizontalAlignment="Right"
                                    Click="Button_Click"
                                    Content="{x:Bind SaveButton.Content, Mode=OneWay}"
                                    IsEnabled="{x:Bind Provider.IsDirty, Mode=OneWay}"
                                    Tag="Save" />
                            </StackPanel>
                        </Flyout>
                    </Button.Flyout>
                </Button>
                <Button
                    x:Uid="/ManagePage/RefreshButton"
                    Width="100"
                    VerticalAlignment="Center"
                    Click="Button_Click"
                    Tag="Refresh">
                    <Button.KeyboardAccelerators>
                        <KeyboardAccelerator Key="F5" />
                    </Button.KeyboardAccelerators>
                </Button>
            </StackPanel>
        </ScrollViewer>
        <cwuc:DataGrid
            x:Name="DataGrid"
            Grid.Row="1"
            AutoGenerateColumns="False"
            CanUserReorderColumns="True"
            CanUserResizeColumns="True"
            CanUserSortColumns="True"
            FrozenColumnCount="1"
            GridLinesVisibility="Horizontal"
            ItemsSource="{x:Bind Provider.FilteredAppContainers, Mode=OneWay}"
            RowDetailsVisibilityMode="{Binding SelectedValue, ElementName=DataGridRowDetailsVisibilityMode}"
            Sorting="DataGrid_Sorting">
            <cwuc:DataGrid.RowDetailsTemplate>
                <DataTemplate x:DataType="metadata:AppContainer">
                    <Grid
                        Padding="12,8"
                        ColumnSpacing="8"
                        RowSpacing="8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>
                        <TextBlock
                            x:Uid="/ManagePage/DisplayName"
                            Grid.Row="0"
                            Grid.Column="0"
                            HorizontalAlignment="Left"
                            VerticalAlignment="Top"
                            Foreground="{ThemeResource TextFillColorPrimaryBrush}" />
                        <TextBlock
                            Grid.Row="0"
                            Grid.Column="1"
                            HorizontalAlignment="Left"
                            VerticalAlignment="Top"
                            Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                            IsTextSelectionEnabled="True"
                            Text="{x:Bind DisplayName}"
                            TextWrapping="WrapWholeWords" />
                        <TextBlock
                            x:Uid="/ManagePage/AppContainerName"
                            Grid.Row="1"
                            Grid.Column="0"
                            HorizontalAlignment="Left"
                            VerticalAlignment="Top"
                            Foreground="{ThemeResource TextFillColorPrimaryBrush}" />
                        <TextBlock
                            Grid.Row="1"
                            Grid.Column="1"
                            HorizontalAlignment="Left"
                            VerticalAlignment="Top"
                            Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                            IsTextSelectionEnabled="True"
                            Text="{x:Bind AppContainerName}"
                            TextWrapping="Wrap" />
                        <TextBlock
                            x:Uid="/ManagePage/PackageFullName"
                            Grid.Row="2"
                            Grid.Column="0"
                            HorizontalAlignment="Left"
                            VerticalAlignment="Top"
                            Foreground="{ThemeResource TextFillColorPrimaryBrush}" />
                        <TextBlock
                            Grid.Row="2"
                            Grid.Column="1"
                            HorizontalAlignment="Left"
                            VerticalAlignment="Top"
                            Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                            IsTextSelectionEnabled="True"
                            Text="{x:Bind PackageFullName}"
                            TextWrapping="Wrap" />
                        <TextBlock
                            x:Uid="/ManagePage/AppContainerSid"
                            Grid.Row="3"
                            Grid.Column="0"
                            HorizontalAlignment="Left"
                            VerticalAlignment="Top"
                            Foreground="{ThemeResource TextFillColorPrimaryBrush}" />
                        <TextBlock
                            Grid.Row="3"
                            Grid.Column="1"
                            HorizontalAlignment="Left"
                            VerticalAlignment="Top"
                            Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                            IsTextSelectionEnabled="True"
                            Text="{x:Bind AppContainerSid}"
                            TextWrapping="Wrap" />
                        <TextBlock
                            x:Uid="/ManagePage/UserSid"
                            Grid.Row="4"
                            Grid.Column="0"
                            HorizontalAlignment="Left"
                            VerticalAlignment="Top"
                            Foreground="{ThemeResource TextFillColorPrimaryBrush}" />
                        <TextBlock
                            Grid.Row="4"
                            Grid.Column="1"
                            HorizontalAlignment="Left"
                            VerticalAlignment="Top"
                            Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                            IsTextSelectionEnabled="True"
                            Text="{x:Bind UserSid}"
                            TextWrapping="Wrap" />
                        <TextBlock
                            x:Uid="/ManagePage/WorkingDirectory"
                            Grid.Row="5"
                            Grid.Column="0"
                            HorizontalAlignment="Left"
                            VerticalAlignment="Top"
                            Foreground="{ThemeResource TextFillColorPrimaryBrush}" />
                        <TextBlock
                            Grid.Row="5"
                            Grid.Column="1"
                            HorizontalAlignment="Left"
                            VerticalAlignment="Top"
                            Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                            IsTextSelectionEnabled="True"
                            Text="{x:Bind WorkingDirectory}"
                            TextWrapping="Wrap" />
                        <TextBlock
                            x:Uid="/ManagePage/Capabilities"
                            Grid.Row="6"
                            Grid.Column="0"
                            HorizontalAlignment="Left"
                            VerticalAlignment="Top"
                            Foreground="{ThemeResource TextFillColorPrimaryBrush}" />
                        <ItemsControl
                            Grid.Row="6"
                            Grid.Column="1"
                            HorizontalAlignment="Left"
                            VerticalAlignment="Top"
                            ItemsSource="{x:Bind Capabilities}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate x:DataType="x:String">
                                    <TextBlock
                                        HorizontalAlignment="Left"
                                        Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                        IsTextSelectionEnabled="True"
                                        Text="{x:Bind}"
                                        TextWrapping="Wrap" />
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </Grid>
                </DataTemplate>
            </cwuc:DataGrid.RowDetailsTemplate>
            <cwuc:DataGrid.Columns>
                <cwuc:DataGridTemplateColumn
                    x:Uid="/ManagePage/ExemptColumn"
                    Width="85"
                    CanUserResize="False"
                    CanUserSort="True"
                    IsReadOnly="True"
                    Tag="IsEnableLoop">
                    <cwuc:DataGridTemplateColumn.CellTemplate>
                        <DataTemplate x:DataType="metadata:AppContainer">
                            <CheckBox
                                MinWidth="0"
                                HorizontalAlignment="Center"
                                VerticalAlignment="Center"
                                Click="ToggleSwitch_Toggled"
                                IsChecked="{x:Bind IsEnableLoop, Mode=TwoWay}" />
                        </DataTemplate>
                    </cwuc:DataGridTemplateColumn.CellTemplate>
                </cwuc:DataGridTemplateColumn>
                <cwuc:DataGridTemplateColumn
                    x:Uid="/ManagePage/DisplayNameColumn"
                    Width="150"
                    CanUserResize="True"
                    CanUserSort="True"
                    IsReadOnly="True"
                    Tag="DisplayName">
                    <cwuc:DataGridTemplateColumn.CellTemplate>
                        <DataTemplate x:DataType="metadata:AppContainer">
                            <Border
                                Padding="8"
                                HorizontalAlignment="Stretch"
                                VerticalAlignment="Stretch"
                                Background="{ThemeResource SystemControlTransparentBrush}"
                                Visibility="{x:Bind DisplayName, Converter={StaticResource StringVisibilityConverter}}">
                                <Border.ContextFlyout>
                                    <MenuFlyout>
                                        <MenuFlyoutItem
                                            x:Name="Copy"
                                            x:Uid="/ManagePage/CopyMenu"
                                            Click="MenuFlyoutItem_Click"
                                            Tag="{x:Bind DisplayName}">
                                            <MenuFlyoutItem.Icon>
                                                <FontIcon FontFamily="{StaticResource SymbolThemeFontFamily}" Glyph="&#xE8C8;" />
                                            </MenuFlyoutItem.Icon>
                                        </MenuFlyoutItem>
                                    </MenuFlyout>
                                </Border.ContextFlyout>
                                <TextBlock
                                    VerticalAlignment="Center"
                                    Text="{x:Bind DisplayName}"
                                    TextTrimming="CharacterEllipsis"
                                    ToolTipService.ToolTip="{x:Bind DisplayName}" />
                            </Border>
                        </DataTemplate>
                    </cwuc:DataGridTemplateColumn.CellTemplate>
                </cwuc:DataGridTemplateColumn>
                <cwuc:DataGridTemplateColumn
                    x:Uid="/ManagePage/AppFullNameColumn"
                    Width="400"
                    CanUserResize="True"
                    CanUserSort="True"
                    IsReadOnly="True"
                    Tag="AppContainerName">
                    <cwuc:DataGridTemplateColumn.CellTemplate>
                        <DataTemplate x:DataType="metadata:AppContainer">
                            <Border
                                Padding="8"
                                HorizontalAlignment="Stretch"
                                VerticalAlignment="Stretch"
                                Background="{ThemeResource SystemControlTransparentBrush}"
                                Visibility="{x:Bind AppContainerName, Converter={StaticResource StringVisibilityConverter}}">
                                <Border.ContextFlyout>
                                    <MenuFlyout>
                                        <MenuFlyoutItem
                                            x:Name="Copy"
                                            x:Uid="/ManagePage/CopyMenu"
                                            Click="MenuFlyoutItem_Click"
                                            Tag="{x:Bind AppContainerName}">
                                            <MenuFlyoutItem.Icon>
                                                <FontIcon FontFamily="{StaticResource SymbolThemeFontFamily}" Glyph="&#xE8C8;" />
                                            </MenuFlyoutItem.Icon>
                                        </MenuFlyoutItem>
                                    </MenuFlyout>
                                </Border.ContextFlyout>
                                <TextBlock
                                    VerticalAlignment="Center"
                                    Text="{x:Bind AppContainerName}"
                                    TextTrimming="CharacterEllipsis"
                                    ToolTipService.ToolTip="{x:Bind AppContainerName}" />
                            </Border>
                        </DataTemplate>
                    </cwuc:DataGridTemplateColumn.CellTemplate>
                </cwuc:DataGridTemplateColumn>
                <cwuc:DataGridTemplateColumn
                    x:Uid="/ManagePage/DirectoryColumn"
                    Width="400"
                    CanUserResize="True"
                    CanUserSort="True"
                    IsReadOnly="True"
                    Tag="WorkingDirectory">
                    <cwuc:DataGridTemplateColumn.CellTemplate>
                        <DataTemplate x:DataType="metadata:AppContainer">
                            <Border
                                Padding="8"
                                HorizontalAlignment="Stretch"
                                VerticalAlignment="Stretch"
                                Background="{ThemeResource SystemControlTransparentBrush}"
                                Visibility="{x:Bind WorkingDirectory, Converter={StaticResource StringVisibilityConverter}}">
                                <Border.ContextFlyout>
                                    <MenuFlyout>
                                        <MenuFlyoutItem
                                            x:Name="Copy"
                                            x:Uid="/ManagePage/CopyMenu"
                                            Click="MenuFlyoutItem_Click"
                                            Tag="{x:Bind WorkingDirectory}">
                                            <MenuFlyoutItem.Icon>
                                                <FontIcon FontFamily="{StaticResource SymbolThemeFontFamily}" Glyph="&#xE8C8;" />
                                            </MenuFlyoutItem.Icon>
                                        </MenuFlyoutItem>
                                        <MenuFlyoutItem
                                            x:Name="Open"
                                            x:Uid="/ManagePage/OpenMenu"
                                            Click="MenuFlyoutItem_Click"
                                            Tag="{x:Bind WorkingDirectory}">
                                            <MenuFlyoutItem.Icon>
                                                <FontIcon FontFamily="{StaticResource SymbolThemeFontFamily}" Glyph="&#xE8DA;" />
                                            </MenuFlyoutItem.Icon>
                                        </MenuFlyoutItem>
                                    </MenuFlyout>
                                </Border.ContextFlyout>
                                <TextBlock
                                    VerticalAlignment="Center"
                                    Text="{x:Bind WorkingDirectory}"
                                    TextTrimming="CharacterEllipsis"
                                    ToolTipService.ToolTip="{x:Bind WorkingDirectory}" />
                            </Border>
                        </DataTemplate>
                    </cwuc:DataGridTemplateColumn.CellTemplate>
                </cwuc:DataGridTemplateColumn>
                <cwuc:DataGridTemplateColumn
                    x:Uid="/ManagePage/PackageFullNameColumn"
                    Width="400"
                    CanUserResize="True"
                    CanUserSort="True"
                    IsReadOnly="True"
                    Tag="PackageFullName">
                    <cwuc:DataGridTemplateColumn.CellTemplate>
                        <DataTemplate x:DataType="metadata:AppContainer">
                            <Border
                                Padding="8"
                                HorizontalAlignment="Stretch"
                                VerticalAlignment="Stretch"
                                Background="{ThemeResource SystemControlTransparentBrush}"
                                Visibility="{x:Bind PackageFullName, Converter={StaticResource StringVisibilityConverter}}">
                                <Border.ContextFlyout>
                                    <MenuFlyout>
                                        <MenuFlyoutItem
                                            x:Name="Copy"
                                            x:Uid="/ManagePage/CopyMenu"
                                            Click="MenuFlyoutItem_Click"
                                            Tag="{x:Bind PackageFullName}">
                                            <MenuFlyoutItem.Icon>
                                                <FontIcon FontFamily="{StaticResource SymbolThemeFontFamily}" Glyph="&#xE8C8;" />
                                            </MenuFlyoutItem.Icon>
                                        </MenuFlyoutItem>
                                    </MenuFlyout>
                                </Border.ContextFlyout>
                                <TextBlock
                                    VerticalAlignment="Center"
                                    Text="{x:Bind PackageFullName}"
                                    TextTrimming="CharacterEllipsis"
                                    ToolTipService.ToolTip="{x:Bind PackageFullName}" />
                            </Border>
                        </DataTemplate>
                    </cwuc:DataGridTemplateColumn.CellTemplate>
                </cwuc:DataGridTemplateColumn>
                <cwuc:DataGridTemplateColumn
                    x:Uid="/ManagePage/AppContainerSidColumn"
                    Width="400"
                    CanUserResize="True"
                    CanUserSort="True"
                    IsReadOnly="True"
                    Tag="AppContainerSid">
                    <cwuc:DataGridTemplateColumn.CellTemplate>
                        <DataTemplate x:DataType="metadata:AppContainer">
                            <Border
                                Padding="8"
                                HorizontalAlignment="Stretch"
                                VerticalAlignment="Stretch"
                                Background="{ThemeResource SystemControlTransparentBrush}"
                                Visibility="{x:Bind AppContainerSid, Converter={StaticResource StringVisibilityConverter}}">
                                <Border.ContextFlyout>
                                    <MenuFlyout>
                                        <MenuFlyoutItem
                                            x:Name="Copy"
                                            x:Uid="/ManagePage/CopyMenu"
                                            Click="MenuFlyoutItem_Click"
                                            Tag="{x:Bind AppContainerSid}">
                                            <MenuFlyoutItem.Icon>
                                                <FontIcon FontFamily="{StaticResource SymbolThemeFontFamily}" Glyph="&#xE8C8;" />
                                            </MenuFlyoutItem.Icon>
                                        </MenuFlyoutItem>
                                    </MenuFlyout>
                                </Border.ContextFlyout>
                                <TextBlock
                                    VerticalAlignment="Center"
                                    Text="{x:Bind AppContainerSid}"
                                    TextTrimming="CharacterEllipsis"
                                    ToolTipService.ToolTip="{x:Bind AppContainerSid}" />
                            </Border>
                        </DataTemplate>
                    </cwuc:DataGridTemplateColumn.CellTemplate>
                </cwuc:DataGridTemplateColumn>
                <cwuc:DataGridTemplateColumn
                    x:Uid="/ManagePage/UserSidColumn"
                    Width="400"
                    CanUserResize="True"
                    CanUserSort="True"
                    IsReadOnly="True"
                    Tag="UserSid">
                    <cwuc:DataGridTemplateColumn.CellTemplate>
                        <DataTemplate x:DataType="metadata:AppContainer">
                            <Border
                                Padding="8"
                                HorizontalAlignment="Stretch"
                                VerticalAlignment="Stretch"
                                Background="{ThemeResource SystemControlTransparentBrush}"
                                Visibility="{x:Bind UserSid, Converter={StaticResource StringVisibilityConverter}}">
                                <Border.ContextFlyout>
                                    <MenuFlyout>
                                        <MenuFlyoutItem
                                            x:Name="Copy"
                                            x:Uid="/ManagePage/CopyMenu"
                                            Click="MenuFlyoutItem_Click"
                                            Tag="{x:Bind UserSid}">
                                            <MenuFlyoutItem.Icon>
                                                <FontIcon FontFamily="{StaticResource SymbolThemeFontFamily}" Glyph="&#xE8C8;" />
                                            </MenuFlyoutItem.Icon>
                                        </MenuFlyoutItem>
                                    </MenuFlyout>
                                </Border.ContextFlyout>
                                <TextBlock
                                    VerticalAlignment="Center"
                                    Text="{x:Bind UserSid}"
                                    TextTrimming="CharacterEllipsis"
                                    ToolTipService.ToolTip="{x:Bind UserSid}" />
                            </Border>
                        </DataTemplate>
                    </cwuc:DataGridTemplateColumn.CellTemplate>
                </cwuc:DataGridTemplateColumn>
            </cwuc:DataGrid.Columns>
        </cwuc:DataGrid>
        <Grid
            Grid.Row="2"
            Height="30"
            Padding="2,0"
            VerticalAlignment="Bottom"
            ColumnSpacing="2">
            <Grid.Resources>
                <Style TargetType="TextBlock">
                    <Setter Property="FontSize" Value="14" />
                </Style>
                <x:Double x:Key="ControlContentThemeFontSize">14</x:Double>
                <x:Double x:Key="ContentControlFontSize">14</x:Double>
                <Thickness x:Key="ComboBoxEditableTextPadding">10,0,30,0</Thickness>
                <x:Double x:Key="ComboBoxMinHeight">24</x:Double>
                <Thickness x:Key="ComboBoxPadding">12,1,0,3</Thickness>
            </Grid.Resources>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <TextBlock
                Grid.Column="0"
                Padding="10,0"
                HorizontalAlignment="Left"
                VerticalAlignment="Center"
                FontWeight="Bold"
                TextTrimming="CharacterEllipsis"
                ToolTipService.ToolTip="{x:Bind Provider.Message, Mode=OneWay}">
                <Run x:Uid="/ManagePage/StatusPrefix" />
                <Run Text="{x:Bind Provider.Message, Mode=OneWay}" />
            </TextBlock>
            <ComboBox
                x:Name="DataGridRowDetailsVisibilityMode"
                x:Uid="/ManagePage/RowDetailsVisibilityMode"
                Grid.Column="1"
                HorizontalAlignment="Right"
                VerticalAlignment="Center"
                ItemsSource="{x:Bind viewmodels:ManageViewModel.DataGridRowDetailsVisibilityModes}"
                SelectedIndex="0">
                <ComboBox.ItemTemplate>
                    <DataTemplate x:DataType="cwuc:DataGridRowDetailsVisibilityMode">
                        <TextBlock local:DataGridRowDetailsVisibilityModeConverter.VisibilityMode="{x:Bind}" ToolTipService.ToolTip="{x:Bind}" />
                    </DataTemplate>
                </ComboBox.ItemTemplate>
            </ComboBox>
        </Grid>
    </Grid>
</Page>
